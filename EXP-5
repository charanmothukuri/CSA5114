#include <stdio.h>
#include <string.h>
#include <ctype.h>

int gcd(int a, int b) {
    while (b != 0) {
        int temp = b;
        b = a % b;
        a = temp;
    }
    return a;
}

int main() {
    char plaintext[100], ciphertext[100];
    int a, b, i;

    printf("Enter Plaintext: ");
    scanf("%s", plaintext);

    printf("Enter value of a: ");
    scanf("%d", &a);

    printf("Enter value of b: ");
    scanf("%d", &b);

    
    if (gcd(a, 26) != 1) {
        printf("\nInvalid value of a!\n");
        printf("'a' must be coprime with 26.\n");
        return 0;
    }

    
    for (i = 0; plaintext[i] != '\0'; i++) {
        char ch = toupper(plaintext[i]);

        if (isalpha(ch)) {
            int p = ch - 'A';
            int c = (a * p + b) % 26;
            ciphertext[i] = c + 'A';
        } else {
            ciphertext[i] = ch;
        }
    }

    ciphertext[i] = '\0';

    printf("\nCiphertext: %s\n", ciphertext);

    return 0;
}
